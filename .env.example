# ─── Database ───────────────────────────────────────────────────────────────
# Async SQLAlchemy DSN using asyncpg driver (used by the API inside Docker)
DATABASE_URL=postgresql+asyncpg://taskpilot:taskpilot@localhost:5432/taskpilot

# Used by Alembic (synchronous psycopg2 driver) for migrations
# Inside Docker, Alembic runs before uvicorn and connects via the internal network.
# For local dev (outside Docker), use port 5433 (host-side mapping).
DATABASE_URL_SYNC=postgresql+psycopg2://taskpilot:taskpilot@localhost:5432/taskpilot

# ─── Authentication ─────────────────────────────────────────────────────────
# HTTP Basic Auth credentials (change before deploying)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=changeme

# ─── Worker ─────────────────────────────────────────────────────────────────
# How often the worker polls for due tasks (seconds)
WORKER_POLL_INTERVAL=60

# Maximum retry attempts before a task is marked dead
MAX_RETRIES=3

# ─── App ────────────────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API from a browser.
# In production, replace with your real frontend domain.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
